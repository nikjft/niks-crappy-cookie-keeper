{
  "name": "niks-crappy-cookie-keeper",
  "version": "1.0.0",
  "description": "Mirrored server-side/client-side cookie keeper",
  "main": "worker.js",
  "scripts": {
    "build": "node build.js",
    "dev": "node build.js && wrangler dev worker.js --port 8787",
    "serve": "npx http-server -p 3000 -c-1",
    "deploy": "node build.js && wrangler deploy worker.js"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "terser": "^5.48.0",
    "wrangler": "^3.0.0"
  }
}
